{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "dev",
			"path": "frontend",
			"problemMatcher": [],
			"label": "npm: dev - frontend",
			"detail": "vite",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "shell",
			"label": "Biome: 一括整形とチェック",
			"command": "npx @biomejs/biome check --write ./src",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			}
		},
		{
			"type": "shell",
			"label": "Ruff: バックエンド整形",
			"command": "python -m ruff check --fix .",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent",
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "コード一括整形 (React & Python)",
			"dependsOn": ["Biome: フロントエンド整形", "Ruff: バックエンド整形"],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		}
	]
}
